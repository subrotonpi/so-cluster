    <script src="https://usaskcdn.ca/limestone/stable/js/limestone.min.js"></script>
    <script type="text/javascript">
         window.onload = function() {
            const regex = /^https?::\/\/www(test)?1\.usask\.ca\/test\/404\.php$/
            const url = window.location.href;
            if (url != "https://wwwtest1.usask.ca/test/404.php" && url != "https://www1.usask.ca/test/404.php") {
                const pageNotFoundDiv = document.getElementById("func404location");
                pageNotFoundDiv.innerHTML = `<p><b>URL:</b> ${url}</p>`;
            } else {
                console.log(`match: ${url}`);
            }
        };
    </script>
